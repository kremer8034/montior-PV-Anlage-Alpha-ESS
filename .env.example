# ---------------------------------------------------------------------------
# Alpha-ESS-Zugangsdaten  (NICHT committen! In Vercel als Environment Variables)
# Registrierung: https://open.alphaess.com  ->  Developer-Konto
# ---------------------------------------------------------------------------
ALPHAESS_APP_ID=
ALPHAESS_APP_SECRET=

# Seriennummern aller Anlagen, kommagetrennt (z. B. ALxxx1,ALxxx2,ALxxx3).
# Leer lassen, um alle am Konto verknüpften Anlagen automatisch zu laden.
ALPHAESS_SN_LIST=

# Optional ----------------------------------------------------------------
# Cache-Dauer in Sekunden (schont die API-Limits). Standard: 30
CACHE_TTL_SECONDS=30
# CO2-Faktor kg/kWh (deutscher Strommix ~0,4). Standard: 0.4
CO2_FACTOR_KG_PER_KWH=0.4
# Demo-Modus erzwingen ("true") oder abschalten ("false").
# Ohne APP_ID ist der Demo-Modus automatisch aktiv.
DEMO_MODE=
# Abweichende API-Basis-URL (nur falls nötig)
# ALPHAESS_BASE_URL=https://openapi.alphaess.com/api
